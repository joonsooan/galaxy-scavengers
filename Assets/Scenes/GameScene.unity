  tooltipPanel: {fileID: 1922431905}
  tooltipText: {fileID: 1158699060}
  tooltipMinerNoResource: "\uCC44\uAD74 \uC720\uB2DB\uC774 \uCE98 \uC790\uC6D0\uC774
    \uC5C6\uC2B5\uB2C8\uB2E4.\n\uC0C8\uB85C\uC6B4 \uC790\uC6D0 \uBE14\uB85D\uC744
    \uCC3E\uC73C\uC138\uC694!"
  tooltipMinerIsFull: "\uCC44\uAD74 \uC720\uB2DB\uC774 \uC790\uC6D0\uC744 \uC800\uC7A5\uD560
    \uACF5\uAC04\uC774 \uC5C6\uC2B5\uB2C8\uB2E4.\n\uC800\uC7A5\uACE0\uB97C \uB354
    \uAC74\uC124\uD558\uC138\uC694!"
  tooltipUnitUnderAttack: "\uC720\uB2DB\uC774 \uACF5\uACA9\uBC1B\uACE0 \uC788\uC2B5\uB2C8\uB2E4!"
  tooltipBuildingUnderAttack: "\uAC74\uBB3C\uC774 \uACF5\uACA9\uBC1B\uACE0 \uC788\uC2B5\uB2C8\uB2E4!"
  tooltipDroneIsNotAssigned: "\uAC00\uACF5 \uC720\uB2DB\uC774 \uC0DD\uC0B0 \uAC74\uBB3C\uC5D0\n\uBC30\uC815\uB418\uC9C0
    \uC54A\uC558\uC2B5\uB2C8\uB2E4.\n\uC0DD\uC0B0 \uAC74\uBB3C\uC5D0 \uBC30\uC815\uD574\uC8FC\uC138\uC694!"
  tooltipDroneNoResource: "\uAC00\uACF5 \uC720\uB2DB\uC774 \uAC00\uACF5\uD560 \uC790\uC6D0\uC774
    \uBD80\uC871\uD569\uB2C8\uB2E4."
  tooltipConstructNoResource: "\uAC74\uC124 \uC720\uB2DB\uC774 \uAC74\uC124\uD560
    \uC790\uC6D0\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
  tooltipStorageFull: "\uBAA8\uB4E0 \uC800\uC7A5 \uACF5\uAC04\uC774 \uAC00\uB4DD
    \uCC3C\uC2B5\uB2C8\uB2E4!\n\uC800\uC7A5\uACE0\uB97C \uB354 \uAC74\uC124\uD558\uC138\uC694."
  tooltipElecInsufficient: "\uC804\uB825\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4!\n\uBC1C\uC804\uAE30\uB97C
    \uB354 \uAC74\uC124\uD558\uC138\uC694."
  tooltipNoiseCaution: "\uC18C\uC74C \uC815\uB3C4 : \uC8FC\uC758\n\uBC24\uC774 \uB418\uBA74
    \uC801\uC758 \uC2B5\uACA9\uC5D0 \uB300\uBE44\uD558\uC138\uC694!"
  tooltipNoiseWarning: "\uC18C\uC74C \uC815\uB3C4 : \uACBD\uACE0\n\uBC24\uC774 \uB418\uBA74
