  m_SharedData: {fileID: 11400000, guid: 45bfd075af41d444398d0bcd56727079, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 236655022080
    m_Localized: "\uC800\uC7A5\uACE0"
    m_Metadata:
      m_Items: []
  - m_Id: 714168143872
    m_Localized: "\uC790\uC6D0\uC744 \uC800\uC7A5\uD560 \uC218 \uC788\uB294 \uCC3D\uACE0\uC785\uB2C8\uB2E4.
      \uC720\uB2DB\uB4E4\uC740 \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC800\uC7A5\uACE0\uB85C
      \uC790\uC6D0\uC744 \uC6B4\uBC18\uD558\uAC70\uB098 \uAEBC\uB0B4\uC11C \uC0AC\uC6A9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9262927253504
    m_Localized: "\uBC1C\uC804\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 9295831568384
    m_Localized: "\uC5D0\uD14C\uB974\uB97C \uC18C\uBAA8\uD574 \uC804\uB825\uC744
      \uC0DD\uC0B0\uD558\uB294 \uAC74\uBB3C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9309643411456
    m_Localized: "\uC81C\uB828\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 9312180965376
    m_Localized: "\uAE30\uCD08 \uC790\uC6D0\uC744 \uB179\uC5EC\uC11C \uC0C1\uC704
      \uC790\uC6D0\uC73C\uB85C \uAC00\uACF5\uD558\uB294 \uC2DC\uC124\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9313510559744
    m_Localized: "\uCD95\uC804\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 9314135511040
    m_Localized: "\uC804\uB825\uC744 \uC800\uC7A5\uD558\uC5EC \uC804\uB825\uB9DD
      \uC800\uC7A5 \uC6A9\uB7C9\uC744 \uB298\uB824 \uC90D\uB2C8\uB2E4. \uB2E4\uB978
      \uC885\uB958\uC758 \uC790\uC6D0\uC740 \uC800\uC7A5\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9314676576256
    m_Localized: "\uC720\uB2DB \uCDA9\uC804\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 9315234418688
    m_Localized: "\uC720\uB2DB\uC744 \uCDA9\uC804\uD558\uB294 \uAC74\uBB3C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9315746123776
    m_Localized: "\uD3EC\uD0D1"
    m_Metadata:
      m_Items: []
  - m_Id: 9316333326336
    m_Localized: "\uBC94\uC704 \uB0B4\uC758 \uC801 \uC720\uB2DB\uC744 \uC790\uB3D9\uC73C\uB85C
      \uACF5\uACA9\uD558\uB294 \uBC29\uC5B4 \uC2DC\uC124\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9316853420032
    m_Localized: "\uCD94\uCD9C\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 9317344153600
    m_Localized: "\uACE0\uB300 \uC794\uD574\uB85C\uBD80\uD130 \uB370\uC774\uD130\uB97C
      \uCD94\uCD9C\uD558\uB294 \uAC74\uBB3C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9317893607424
    m_Localized: "\uC1A1\uC2E0\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 9318392729600
    m_Localized: "\uC804\uB825\uC744 \uB2E4\uB978 \uACF3\uC73C\uB85C \uBCF4\uB0B4\uB294
      \uAC74\uBB3C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9319030263808
    m_Localized: "\uC2DC\uB4DC \uCF54\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680704
    m_Localized: "\uAE30\uC9C0\uC758 \uC911\uC2EC\uC774 \uB418\uB294 \uD575\uC2EC
      \uAC74\uBB3C\uC785\uB2C8\uB2E4. \uBAA8\uC120\uC73C\uB85C \uAC00\uC838\uAC08
      \uC790\uC6D0\uC744 \uAD00\uB9AC\uD560 \uC218 \uC788\uC73C\uBA70, \uD30C\uAD34\uB418\uBA74
      \uAC8C\uC784 \uC624\uBC84\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680705
    m_Localized: "\uBAA8\uB4C8 \uC2A4\uD14C\uC774\uC158"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680706
    m_Localized: "\uC2DC\uB4DC\uCF54\uC5B4\uC5D0 \uC124\uCE58\uD560 \uC218 \uC788\uB294
      \uBAA8\uB4C8\uC744 \uC81C\uC791\uD558\uB294 \uC2A4\uD14C\uC774\uC158\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680707
    m_Localized: "\uAE30\uBCF8 \uBAA8\uB4C8"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680708
    m_Localized: "\uC2DC\uB4DC \uCF54\uC5B4\uC758 \uCC3D\uACE0 \uACF5\uAC04\uC744
      \uC870\uAE08 \uB298\uB824\uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680709
    m_Localized: "\uAC74\uBB3C \uAC15\uD654 \uBAA8\uB4C8 1"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680710
    m_Localized: "\uBAA8\uB4E0 \uAC74\uBB3C\uC758 \uCCB4\uB825\uC774 \uC18C\uD3ED
      \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680711
    m_Localized: "\uAC74\uBB3C \uAC15\uD654 \uBAA8\uB4C8 2"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680712
    m_Localized: "\uBAA8\uB4E0 \uAC74\uBB3C\uC758 \uCCB4\uB825\uC774 \uB354\uC6B1
      \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680713
    m_Localized: "\uC0DD\uC0B0 \uAC15\uD654 \uBAA8\uB4C8 1"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680714
    m_Localized: "\uC790\uC6D0 \uC0DD\uC0B0 \uC18D\uB3C4\uAC00 \uC870\uAE08 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680715
    m_Localized: "\uC0DD\uC0B0 \uAC15\uD654 \uBAA8\uB4C8 2"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680716
    m_Localized: "\uC790\uC6D0 \uC0DD\uC0B0 \uC18D\uB3C4\uAC00 \uB354\uC6B1 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680717
    m_Localized: "\uCC3D\uACE0 \uD655\uC7A5 \uBAA8\uB4C8 1"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680718
    m_Localized: "\uC2DC\uB4DC \uCF54\uC5B4\uC758 \uC800\uC7A5 \uACF5\uAC04\uC744
      \uC870\uAE08 \uD655\uC7A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680719
    m_Localized: "\uCC3D\uACE0 \uD655\uC7A5 \uBAA8\uB4C8 2"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680720
    m_Localized: "\uC2DC\uB4DC \uCF54\uC5B4\uC758 \uC800\uC7A5 \uACF5\uAC04\uC744
      \uB354\uC6B1 \uD655\uC7A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680721
    m_Localized: "\uD3EC\uD0D1 \uAC15\uD654 \uBAA8\uB4C8 1"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680722
    m_Localized: "\uD3EC\uD0D1\uC758 \uACF5\uACA9\uB825\uC774 \uC18C\uD3ED \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680723
    m_Localized: "\uD3EC\uD0D1 \uAC15\uD654 \uBAA8\uB4C8 2"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680724
    m_Localized: "\uD3EC\uD0D1\uC758 \uACF5\uACA9\uB825\uC774 \uB354 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680725
    m_Localized: "\uC720\uB2DB \uAC15\uD654 \uBAA8\uB4C8 1"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680726
    m_Localized: "\uBAA8\uB4E0 \uC720\uB2DB\uC758 \uC774\uB3D9\uC18D\uB3C4, \uC791\uC5C5\uC18D\uB3C4\uAC00
      \uC18C\uD3ED \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680727
    m_Localized: "\uC720\uB2DB \uAC15\uD654 \uBAA8\uB4C8 2"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680728
    m_Localized: "\uBAA8\uB4E0 \uC720\uB2DB\uC758 \uC774\uB3D9\uC18D\uB3C4, \uC791\uC5C5\uC18D\uB3C4\uAC00
      \uB354\uC6B1 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680729
    m_Localized: "\uD589\uC131 0"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680730
    m_Localized: "\uCCAB \uBC88\uC9F8 \uD589\uC131\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680731
    m_Localized: "\uD589\uC131 1"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680732
    m_Localized: "\uB450 \uBC88\uC9F8 \uD589\uC131\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680733
    m_Localized: "\uD589\uC131 2"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680734
    m_Localized: "\uC138 \uBC88\uC9F8 \uD589\uC131\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680735
    m_Localized: "\uC774\uB3D9 \uC18D\uB3C4"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680736
    m_Localized: "\uC720\uB2DB \uC774\uB3D9\uC18D\uB3C4 +10%"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680737
    m_Localized: "\uC720\uB2DB \uC774\uB3D9\uC18D\uB3C4 +15%"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680738
    m_Localized: "\uC791\uC5C5 \uC18D\uB3C4"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680739
    m_Localized: "\uC720\uB2DB \uC791\uC5C5\uC18D\uB3C4 +20%"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680740
    m_Localized: "\uC720\uB2DB \uC791\uC5C5\uC18D\uB3C4 +30%"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680741
    m_Localized: "\uC800\uC7A5\uB7C9"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680742
    m_Localized: "\uC790\uC6D0 \uC6B4\uBC18\uB7C9 +10"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680743
    m_Localized: "\uC790\uC6D0 \uC6B4\uBC18\uB7C9 +20"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680744
    m_Localized: "\uC720\uB2DB \uC22B\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680745
    m_Localized: "\uCD5C\uB300 \uC720\uB2DB +5"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680746
    m_Localized: "\uC81C\uB828\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680747
    m_Localized: "\uAE30\uCD08 \uC790\uC6D0\uC744 \uB179\uC5EC\uC11C \uC0C1\uC704
      \uC790\uC6D0\uC73C\uB85C \uAC00\uACF5\uD558\uB294 \uC2DC\uC124\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2416123601219584
    m_Localized: "\uCD5C\uB300 \uC720\uB2DB +10"
    m_Metadata:
      m_Items: []
  - m_Id: 2421686376591360
    m_Localized: "Galaxy Scavengers\uC758 \uC138\uACC4\uC5D0 \uC624\uC2E0 \uAC83\uC744
      \uD658\uC601\uD569\uB2C8\uB2E4.\\n\uD654\uBA74\uC744 \uD074\uB9AD\uD574\uBCF4\uC138\uC694!"
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534400
    m_Localized: "<color=#FFC107>WASD \uD0A4</color>\uB97C \uC0AC\uC6A9\uD574 \uBA54\uC778
      \uC720\uB2DB\uC744 \uC6C0\uC9C1\uC5EC\uBD05\uC2DC\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534401
    m_Localized: "\uC88B\uC2B5\uB2C8\uB2E4!\\n<color=#FFC107>\uB9C8\uC6B0\uC2A4 \uD720</color>\uC744
      \uC0AC\uC6A9\uD558\uC5EC \uD655\uB300/\uCD95\uC18C\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534402
    m_Localized: "<color=#FFC107>Space \uD0A4</color>\uB97C \uB204\uB974\uAC70\uB098
      <color=#FFC107>\uC544\uC774\uCF58\uC744 \uD074\uB9AD</color>\uD574 \uC2DC\uAC04\uC744
      \uC77C\uC2DC\uC815\uC9C0\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534403
    m_Localized: "\uBA54\uC778 \uC720\uB2DB\uC744 \uC790\uC6D0 \uBB34\uB354\uAE30
      \uADFC\uCC98\uB85C \uC774\uB3D9\uC2DC\uD0A8 \uB2E4\uC74C, <color=#FFC107>\uC790\uC6D0
      \uBE14\uB85D\uC744 \uD074\uB9AD</color>\uD558\uBA74 \uCC44\uAD74\uC744 \uC2DC\uC791\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4.\\n\uD68C\uC0C9 \uC790\uC6D0\uC758 <color=#DBD1C7>\uD398\uB77C\uC774\uD2B8</color>\uB97C
      10\uAC1C \uCC44\uAD74\uD574\uBD05\uC2DC\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534404
    m_Localized: "\uC790\uC6D0 \uBE14\uB85D\uB4E4\uC740 \uB9F5 \uACF3\uACF3\uC5D0
      \uD769\uC5B4\uC838 \uC788\uC73C\uBA70, \uCC44\uAD74\uD560 \uC790\uC6D0\uC774
      \uBAA8\uC790\uB77C\uC9C0 \uC54A\uB3C4\uB85D \uD0D0\uC0AC\uB97C \uAFB8\uC900\uD788
      \uD574\uC57C \uD569\uB2C8\uB2E4.\\n<color=#DBD1C7>(\uD654\uBA74\uC744 \uD074\uB9AD\uD574\uC11C
      \uB2E4\uC74C)</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534405
    m_Localized: "<color=#FFC107>\uD654\uBA74\uC744 \uD074\uB9AD</color>\uD574 \uC5D0\uB108\uC9C0
      \uD0C4\uC744 \uBC1C\uC0AC\uD574\uBD05\uC2DC\uB2E4.\\n\uC068 \uB204\uB974\uBA74
      \uC5F0\uC18D\uC73C\uB85C \uC5D0\uB108\uC9C0 \uD0C4\uC744 \uBC1C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534406
    m_Localized: "\uC88B\uC2B5\uB2C8\uB2E4.\\n\uC774\uC81C \uC911\uC559\uC5D0 \uC788\uB294
      <color=#FFC107>\uC2DC\uB4DC \uCF54\uC5B4</color>\uB97C \uD074\uB9AD\uD55C \uB2E4\uC74C
      <color=#FFC107>\uCC44\uAD74 \uC720\uB2DB</color>\uC744 \uD558\uB098 \uC0DD\uC0B0\uD574\uBD05\uC2DC\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534407
    m_Localized: "<color=#FFC107>\uCC44\uAD74 \uC720\uB2DB</color>\uC740 \uC790\uB3D9\uC73C\uB85C
      \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC790\uC6D0\uC744 \uCC44\uAD74\uD55C \uB2E4\uC74C,
      \uAC00\uAE4C\uC6B4 \uC800\uC7A5\uACE0\uB85C \uC6B4\uBC18\uD569\uB2C8\uB2E4.\\n<color=#DBD1C7>(\uD654\uBA74\uC744
      \uD074\uB9AD\uD574\uC11C \uB2E4\uC74C)</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534408
    m_Localized: "\uB2E4\uC2DC \uC2DC\uB4DC \uCF54\uC5B4\uB97C \uD074\uB9AD\uD55C
      \uB2E4\uC74C <color=#FFC107>\uAC74\uC124 \uC720\uB2DB</color> 2\uAC1C\uB97C
      \uC0DD\uC0B0\uD574\uBD05\uC2DC\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534409
    m_Localized: "\uC88B\uC2B5\uB2C8\uB2E4.\\n<color=#FFC107>\uAE30\uCD08 \uAC74\uBB3C
      \uBC84\uD2BC</color>\uC744 \uD074\uB9AD\uD55C \uB2E4\uC74C, <color=#FFC107>\uC800\uC7A5\uACE0</color>\uB97C
      \uC120\uD0DD\uD55C \uD6C4 \uAE30\uC9C0 \uADFC\uCC98\uC5D0 \uC124\uCE58\uD574\uBCF4\uC138\uC694.\\n\uAC74\uBB3C\uC744
      \uC124\uCE58\uD558\uBA74 <color=#FFC107>\uAC74\uC124 \uC720\uB2DB</color>\uC774
      \uC790\uB3D9\uC73C\uB85C \uC790\uC6D0\uC744 \uC6B4\uBC18\uD558\uC5EC \uAC74\uC124
      \uC791\uC5C5\uC744 \uC9C4\uD589\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534410
    m_Localized: "\uD654\uBA74\uC744 <color=#FFC107>\uC6B0\uD074\uB9AD</color>\uD558\uBA74
      \uD604\uC7AC \uC120\uD0DD\uD55C \uAC74\uBB3C\uC774\uB098 UI\uB97C \uBE44\uD65C\uC131\uD654\uD560
      \uC218 \uC788\uACE0, <color=#FF7043>\uC6B0\uD074\uB9AD\uD55C \uC0C1\uD0DC\uB85C
      \uB4DC\uB798\uADF8</color>\uB97C \uD558\uBA74 \uBC94\uC704 \uB0B4\uC758 \uAC74\uBB3C\uC774\uB098
      \uC720\uB2DB\uC744 \uC81C\uAC70\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\\n<color=#DBD1C7>(\uD654\uBA74\uC744
      \uD074\uB9AD\uD574\uC11C \uB2E4\uC74C)</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534411
    m_Localized: "\uC774\uC81C \uCC44\uAD74\uD55C \uC790\uC6D0\uC744 \uC0C1\uC704
      \uC790\uC6D0\uC73C\uB85C \uAC00\uACF5\uD574\uBD05\uC2DC\uB2E4.\\n\uC790\uC6D0\uC744
      \uAC00\uACF5\uD558\uB824\uBA74 \uC804\uB825\uC774 \uD544\uC694\uD569\uB2C8\uB2E4.\\n<color=#FFC107>\uBC1C\uC804\uAE30</color>\uB97C
      \uC120\uD0DD\uD55C \uB2E4\uC74C \uD558\uB298\uC0C9 \uBC94\uC704 \uC548\uC5D0
      \uC800\uC7A5\uACE0\uB098 \uC2DC\uB4DC \uCF54\uC5B4\uAC00 \uB4E4\uC5B4\uAC00\uB3C4\uB85D
      \uC124\uCE58\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534412
    m_Localized: "\uB2E4\uC74C\uC73C\uB85C <color=#FFC107>\uC81C\uB828\uC18C</color>\uB97C
      \uC120\uD0DD\uD574 \uBC1C\uC804\uAE30\uC758 \uBC94\uC704 \uC548\uC5D0 \uC124\uCE58\uD574\uBCF4\uC138\uC694.\\n\uBC1C\uC804\uAE30\uB294
      \uBC94\uC704 \uC548\uC5D0 \uC788\uB294 \uAC74\uBB3C\uC5D0\uAC8C \uC804\uB825\uC744
      \uACF5\uAE09\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534413
    m_Localized: "\uB9C8\uC9C0\uB9C9\uC73C\uB85C \uC2DC\uB4DC \uCF54\uC5B4\uB97C
      \uD074\uB9AD\uD55C \uB2E4\uC74C <color=#FFC107>\uAC00\uACF5 \uC720\uB2DB</color>
      1\uAC1C\uB97C \uC0DD\uC0B0\uD574\uBD05\uC2DC\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534414
    m_Localized: "<color=#FFC107>\uC81C\uB828\uC18C</color>\uC640 \uAC19\uC740 \uC0DD\uC0B0
      \uAC74\uBB3C\uC740 <color=#FFC107>\uAC00\uACF5 \uC720\uB2DB</color>\uC774 \uBC30\uC815\uB418\uC5B4\uC57C
      \uC790\uC6D0 \uAC00\uACF5\uC744 \uC9C4\uD589\uD569\uB2C8\uB2E4.\\n\uAC00\uACF5
      \uC720\uB2DB\uC740 \uC790\uB3D9\uC73C\uB85C \uBE48 \uC0DD\uC0B0 \uAC74\uBB3C\uC5D0
      \uBC30\uC815\uB429\uB2C8\uB2E4.\\n<color=#DBD1C7>(\uD654\uBA74\uC744 \uD074\uB9AD\uD574\uC11C
      \uB2E4\uC74C)</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534415
    m_Localized: "\uAC00\uACF5 \uC720\uB2DB\uC740 \uAC00\uAE4C\uC6B4 \uC800\uC7A5\uC18C\uC5D0\uC11C
      \uC790\uC6D0\uC744 \uAC00\uC838\uC628 \uB2E4\uC74C \uAC00\uACF5\uD558\uAE30
      \uC2DC\uC791\uD569\uB2C8\uB2E4.\\n\uBC29\uAE08 \uAC74\uC124\uD55C <color=#FFC107>\uC81C\uB828\uC18C</color>\uB97C
      \uD074\uB9AD\uD55C \uB2E4\uC74C, <color=#DBD1C7>\uD569\uAE08 \uD310 5\uAC1C</color>\uB97C
      \uC0DD\uC0B0\uD574\uBD05\uC2DC\uB2E4.\\nCtrl \uD074\uB9AD\uC73C\uB85C 10\uAC1C,
      Shift \uD074\uB9AD\uC73C\uB85C 100\uAC1C \uB2E8\uC704\uB85C \uC0DD\uC0B0\uB7C9\uC744
      \uC870\uC808\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 2421686418534416
    m_Localized: "\uD6CC\uB96D\uD569\uB2C8\uB2E4! Galaxy Scavengers\uC758 \uAE30\uBCF8
      \uC870\uC791\uC744 \uBAA8\uB450 \uC775\uD788\uC168\uAD70\uC694.\\n\uB0A8\uC740
      \uC77C\uC740 \uCD94\uCD9C\uAE30\uB97C \uD558\uC0C9 \uD0C0\uC77C\uC5D0 \uC124\uCE58\uD574
      \uB370\uC774\uD130\uB97C \uCD5C\uB300\uD55C \uCD94\uCD9C\uD558\uACE0 \uD589\uC131\uC744
      \uB5A0\uB098\uB294 \uC77C\uC785\uB2C8\uB2E4.\\n\uADF8\uB7FC, \uAC74\uD22C\uB97C
      \uBE55\uC2DC\uB2E4.\\n<color=#DBD1C7>(\uD654\uBA74\uC744 \uC068 \uB20C\uB7EC\uC11C
      \uB2EB\uAE30)</color>"
    m_Metadata:
      m_Items: []
