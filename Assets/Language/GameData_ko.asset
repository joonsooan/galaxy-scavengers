  m_TableData:
  - m_Id: 236655022080
    m_Localized: "\uC800\uC7A5\uACE0"
    m_Metadata:
      m_Items: []
  - m_Id: 714168143872
    m_Localized: "\uC790\uC6D0\uC744 \uC800\uC7A5\uD560 \uC218 \uC788\uB294 \uCC3D\uACE0\uC785\uB2C8\uB2E4.
      \uC720\uB2DB\uB4E4\uC740 \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uC800\uC7A5\uACE0\uB85C
      \uC790\uC6D0\uC744 \uC6B4\uBC18\uD558\uAC70\uB098 \uAEBC\uB0B4\uC11C \uC0AC\uC6A9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9262927253504
    m_Localized: "\uBC1C\uC804\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 9295831568384
    m_Localized: "\uC5D0\uD14C\uB974\uB97C \uC18C\uBAA8\uD574 \uC804\uB825\uC744
      \uC0DD\uC0B0\uD558\uB294 \uAC74\uBB3C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9309643411456
    m_Localized: "\uC81C\uB828\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 9312180965376
    m_Localized: "\uAE30\uCD08 \uC790\uC6D0\uC744 \uB179\uC5EC\uC11C \uC0C1\uC704
      \uC790\uC6D0\uC73C\uB85C \uAC00\uACF5\uD558\uB294 \uC2DC\uC124\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9313510559744
    m_Localized: "\uCD95\uC804\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 9314135511040
    m_Localized: "\uC804\uB825\uC744 \uC800\uC7A5\uD558\uC5EC \uC804\uB825\uB9DD
      \uC800\uC7A5 \uC6A9\uB7C9\uC744 \uB298\uB824 \uC90D\uB2C8\uB2E4. \uB2E4\uB978
      \uC885\uB958\uC758 \uC790\uC6D0\uC740 \uC800\uC7A5\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9314676576256
    m_Localized: "\uC720\uB2DB \uCDA9\uC804\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 9315234418688
    m_Localized: "\uC720\uB2DB\uC744 \uCDA9\uC804\uD558\uB294 \uAC74\uBB3C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9315746123776
    m_Localized: "\uD3EC\uD0D1"
    m_Metadata:
      m_Items: []
  - m_Id: 9316333326336
    m_Localized: "\uBC94\uC704 \uB0B4\uC758 \uC801 \uC720\uB2DB\uC744 \uC790\uB3D9\uC73C\uB85C
      \uACF5\uACA9\uD558\uB294 \uBC29\uC5B4 \uC2DC\uC124\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9316853420032
    m_Localized: "\uCD94\uCD9C\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 9317344153600
    m_Localized: "\uACE0\uB300 \uC794\uD574\uB85C\uBD80\uD130 \uB370\uC774\uD130\uB97C
      \uCD94\uCD9C\uD558\uB294 \uAC74\uBB3C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9317893607424
    m_Localized: "\uC1A1\uC2E0\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 9318392729600
    m_Localized: "\uC804\uB825\uC744 \uB2E4\uB978 \uACF3\uC73C\uB85C \uBCF4\uB0B4\uB294
      \uAC74\uBB3C\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9319030263808
    m_Localized: "\uC2DC\uB4DC \uCF54\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680704
    m_Localized: "\uAE30\uC9C0\uC758 \uC911\uC2EC\uC774 \uB418\uB294 \uD575\uC2EC
      \uAC74\uBB3C\uC785\uB2C8\uB2E4. \uBAA8\uC120\uC73C\uB85C \uAC00\uC838\uAC08
      \uC790\uC6D0\uC744 \uAD00\uB9AC\uD560 \uC218 \uC788\uC73C\uBA70, \uD30C\uAD34\uB418\uBA74
      \uAC8C\uC784 \uC624\uBC84\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680705
    m_Localized: "\uBAA8\uB4C8 \uC2A4\uD14C\uC774\uC158"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680706
    m_Localized: "\uC2DC\uB4DC\uCF54\uC5B4\uC5D0 \uC124\uCE58\uD560 \uC218 \uC788\uB294
      \uBAA8\uB4C8\uC744 \uC81C\uC791\uD558\uB294 \uC2A4\uD14C\uC774\uC158\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680707
    m_Localized: "\uAE30\uBCF8 \uBAA8\uB4C8"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680708
    m_Localized: "\uC2DC\uB4DC \uCF54\uC5B4\uC758 \uCC3D\uACE0 \uACF5\uAC04\uC744
      \uC870\uAE08 \uB298\uB824\uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680709
    m_Localized: "\uAC74\uBB3C \uAC15\uD654 \uBAA8\uB4C8 1"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680710
    m_Localized: "\uBAA8\uB4E0 \uAC74\uBB3C\uC758 \uCCB4\uB825\uC774 \uC18C\uD3ED
      \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680711
    m_Localized: "\uAC74\uBB3C \uAC15\uD654 \uBAA8\uB4C8 2"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680712
    m_Localized: "\uBAA8\uB4E0 \uAC74\uBB3C\uC758 \uCCB4\uB825\uC774 \uB354\uC6B1
      \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680713
    m_Localized: "\uC0DD\uC0B0 \uAC15\uD654 \uBAA8\uB4C8 1"
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680714
    m_Localized: "\uC790\uC6D0 \uC0DD\uC0B0 \uC18D\uB3C4\uAC00 \uC870\uAE08 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9655828680715
    m_Localized: "\uC0DD\uC0B0 \uAC15\uD654 \uBAA8\uB4C8 2"
