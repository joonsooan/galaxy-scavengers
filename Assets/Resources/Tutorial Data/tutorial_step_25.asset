  text: "\uD654\uBA74 \uC624\uB978\uCABD \uC0C1\uB2E8\uC5D0\uC11C \uD604\uC7AC <color=#FFC107>\uC18C\uC74C
    \uC815\uB3C4</color>\uB97C \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n<color=#FFC107>\uC18C\uC74C
    \uC815\uB3C4</color>\uB294 \uAC74\uBB3C\uC744 \uC124\uCE58\uD558\uAC70\uB098
    \uC720\uB2DB\uC744 \uC0DD\uC0B0\uD558\uBA74 \uC99D\uAC00\uD558\uBA70, \uD589\uC131
    \uD45C\uBA74\uC5D0 \uBA38\uBB34\uB294 \uB3D9\uC548 \uC870\uAE08\uC529 \uC0C1\uC2B9\uD569\uB2C8\uB2E4.\n<color=#FFC107>\uC18C\uC74C
    \uC815\uB3C4</color>\uAC00 \uC77C\uC815 \uC218\uCE58\uB97C \uB118\uC5B4\uAC00\uBA74
    \uBC24\uC5D0 \uC801\uB4E4\uC774 \uACF5\uACA9\uD574\uC624\uB2C8 \uC8FC\uC758\uD558\uC138\uC694!\n\uADF8\uB7FC,
    \uBB34\uC0AC\uD788 \uD589\uC131\uC744 \uD0C8\uCD9C\uD558\uAE38 \uBC14\uB78D\uB2C8\uB2E4!\n<color=#DBD1C7>(\uD074\uB9AD\uD574\uC11C
    \uB9C8\uCE68)</color>"
