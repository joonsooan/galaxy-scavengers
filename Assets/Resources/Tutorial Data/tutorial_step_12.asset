  text: "\uAC74\uBB3C\uC744 \uC124\uCE58\uD558\uBA74 <color=#FFC107>\uAC74\uC124
    \uAD6C\uC5ED</color>\uC774 \uC9C0\uC815\uB418\uBA70, <color=#FFC107>\uAC74\uC124
    \uC720\uB2DB</color>\uB4E4\uC774 \uC790\uB3D9\uC73C\uB85C \uC790\uC6D0\uC744
    \uC6B4\uBC18\uD558\uC5EC \uAC74\uC124 \uC791\uC5C5\uC744 \uC9C4\uD589\uD569\uB2C8\uB2E4.\n\uB9C8\uCE68
    \uAC74\uC124 \uC720\uB2DB \uD558\uB098\uAC00 \uB3C4\uC640\uC8FC\uB7EC \uC654\uB124\uC694!
    \uC791\uC5C5\uD558\uB294 \uBAA8\uC2B5\uC744 \uC9C0\uCF1C\uBD05\uC2DC\uB2E4.\n<color=#FFC107>\uC6B0\uD074\uB9AD</color>\uD558\uBA74
    \uD604\uC7AC \uC120\uD0DD\uD55C \uAC74\uBB3C\uC774\uB098 UI\uB97C \uBE44\uD65C\uC131\uD654\uD560
